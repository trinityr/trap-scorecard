# Copy this to .env and fill in real values. Never commit the real .env.

# Postgres
POSTGRES_DB=trapscores
POSTGRES_USER=trapadmin
POSTGRES_PASSWORD=changeme-use-a-real-password

# The LAN IP of this VM/container (not NPM's), so the api port only
# binds where your Proxmox network can reach it. Leave as 0.0.0.0 if
# you're not sure, but a specific IP is tighter.
API_HOST_IP=192.168.1.50

# Host port to publish the API on. Change this if 3000 is already taken
# by something else on this VM — the container still listens on 3000
# internally regardless, this only affects what NPM (or curl) connects to.
API_HOST_PORT=3000

# Your Anthropic API key, used server-side to read scoresheet photos.
# Get one at https://console.anthropic.com/settings/keys — never put this
# in any client-side code. This is just the bootstrap value — once the
# app is running, an admin can change it from the Admin panel without
# redeploying, and that DB value takes priority over this one.
ANTHROPIC_API_KEY=sk-ant-...

# CORS - restrict this to your actual frontend origin once you have one,
# e.g. https://scores.yourclub.com. Like the API key above, this is just
# the bootstrap value — admins can change it later from the Admin panel.
CORS_ORIGIN=*

# Random secret used to sign session cookies. Generate a real one with:
#   openssl rand -base64 32
# Changing this later invalidates all existing sessions (everyone gets
# signed out) — that's expected, not a bug.
SESSION_SECRET=changeme-generate-a-real-random-secret

# Leave this as "true" once NPM is serving your site over HTTPS (the
# normal case). Only set to "false" temporarily if you're testing by
# hitting this container directly over plain http, without NPM in front —
# secure cookies won't be stored by the browser over a non-https connection.
COOKIE_SECURE=true
